// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Questea Specific
  tasks           Task[]       @relation("UserTasks")
  categories      Category[]
  aliasEmails     AliasEmail[]
  locations       LocationCheckIn[]
  payees          Payee[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  BUG
  IDEA
  EXPENSE
  LOCATION_HISTORY
  LOCATION
  FOLDER
}

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#ea580c") // Výchzí naše krásná oranžová
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  slug        String?  @unique // Custom URL slug for public sharing
  blogTemplate String? @default("MODERN") // Visual style for the public blog
  
  // Základní údaje (Zadání)
  title       String       // Předmět
  description String?  @db.Text // Detailní popis
  
  // Řízení stavu (HelpDesk & Agile parametry)
  status      TaskStatus   @default(TODO) // Stav
  priority    TaskPriority @default(MEDIUM) // Priorita
  taskType    TaskType     @default(TASK) // Zdroj/Typ záznamu
  progress    Int          @default(0) // Progress v procentech (0-100)
  
  // Časování a plánování
  startDate   DateTime?    // Od kdy (začátek plnění)
  dueDate     DateTime?    // Kdy se má odevzdat (splatnost)
  
  spentMinutes     Int?    // Skutečně strávený/vykázaný čas v minutách
  
  // Vazby (Kdo, Komu, Kam, Čí)
  userId      String       // Vlastník/Tvůrce (Kdo úkol založil)
  user        User     @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)

  // Hierarchie (Nadúkoly a Podúkoly)
  parentId     String?
  parent       Task?    @relation("SubTasks", fields: [parentId], references: [id], onDelete: SetNull)
  subTasks     Task[]   @relation("SubTasks")

  categoryId  String?      // Kategorie
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Přílohy a hlasové poznámky
  attachments  Attachment[]
  
  // Expense fields (only if taskType == EXPENSE)
  amount      Float?
  currency    String?      @default("CZK")
  payee       String?      // Komu se platilo
  
  // Location History (only if taskType == LOCATION_HISTORY)
  locations   LocationCheckIn[]
  
  // Systémové
  isDeleted   Boolean  @default(false)
  lockStatus  Boolean  @default(false) // If true, cannot be closed/DONE manually
  orderIndex  Int      @default(0)
  recordedAt  DateTime? // Kdy se to skutečně stalo (pro historii)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payee {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, userId])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   // 'image', 'file', 'note'
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AliasEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified  Boolean  @default(false)
  allowAi   Boolean  @default(true) // Whether AI processing is on by default
  createdAt DateTime @default(now())
}
model LocationCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  latitude  Float
  longitude Float
  address   String?  // Vyhledaná adresa
  placeName String?  // Název místa (pokud ho najdeme)
  note      String?  @db.Text
  photoUrl  String?  // URL nahrané fotky
  mileage   Float?   // Stav tachometru / ujeté km
  
  // Vazba na úkol (pokud je to součást historie cesty)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}
